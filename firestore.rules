rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Session documents. Path format: "{storeNbr}-{YYYY-MM-DD}".
    // Any authenticated user can read/write sessions for any store.
    match /sessions/{sessionId} {
      allow read: if request.auth != null
                  && sessionId.matches('^[0-9]+-[0-9]{4}-[0-9]{2}-[0-9]{2}$');

      allow create: if request.auth != null
                    && sessionId.matches('^[0-9]+-[0-9]{4}-[0-9]{2}-[0-9]{2}$');

      allow update: if request.auth != null
                    && sessionId.matches('^[0-9]+-[0-9]{4}-[0-9]{2}-[0-9]{2}$');

      // Submitted sessions are kept as historical record — no client deletes.
      allow delete: if false;
    }

    // Email settings and server-side config — Admin SDK only, no client access.
    match /config/{doc} {
      allow read, write: if false;
    }

    // Default-deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
